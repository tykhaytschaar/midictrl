# Settings common to every supported target.
# Target-specific overrides (chip, flash size, partition file) live in
# sdkconfig.defaults.<target>. Pick a target with `idf.py set-target esp32`
# or `idf.py set-target esp32s3` (or use tools/build.sh).

# Custom partition table — filename is set per target.
CONFIG_PARTITION_TABLE_CUSTOM=y

# Slightly larger main task stack for the bring-up phase.
CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192

# WebSocket support in esp_http_server — needed by the web_server component.
CONFIG_HTTPD_WS_SUPPORT=y
